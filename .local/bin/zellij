#!/usr/bin/env bash
set -euo pipefail

ZELLIJ_BIN="/usr/bin/zellij"
if [[ ! -x "$ZELLIJ_BIN" ]]; then
  ZELLIJ_BIN="$(command -v zellij)"
fi

for arg in "$@"; do
  if [[ "$arg" == "--config" || "$arg" == "-c" ]]; then
    exec "$ZELLIJ_BIN" "$@"
  fi
done

case "${1:-}" in
  action|attach|convert-config|convert-layout|convert-theme|delete-all-sessions|delete-session|edit|help|kill-all-sessions|kill-session|list-aliases|list-sessions|options|pipe|plugin|run|setup)
    exec "$ZELLIJ_BIN" "$@"
    ;;
esac

sync_helper="$HOME/.config/theme-sync/bin/sync-zellij-theme"
generated_config="$HOME/.config/zellij/.cache/config.auto-theme.kdl"

if [[ -x "$sync_helper" ]]; then
  "$sync_helper" >/dev/null
fi

if [[ -f "$generated_config" ]]; then
  exec "$ZELLIJ_BIN" --config "$generated_config" "$@"
fi

exec "$ZELLIJ_BIN" "$@"
